# ─── Jira & Confluence Credentials ───────────────────────────────────────
# Get tokens from your Jira/Confluence account settings
JIRA_URL=https://jira.example.com
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-bearer-token
CONFLUENCE_URL=https://confluence.example.com
CONFLUENCE_EMAIL=your-email@example.com
CONFLUENCE_API_TOKEN=your-confluence-api-token

# ─── Domain Configuration ─────────────────────────────────────────────────
# Tailor PM skills to your team's context (required for skill contextualisation)
DOMAIN_NAME=Payment Core
JIRA_PROJECT_KEY=PCDPC
CONFLUENCE_SPACES=PAYMENTS,Payment Engine

# ─── Optional: Web Fetcher Settings ───────────────────────────────────────
# WEB_USER_AGENT=Custom Bot 1.0
# WEB_TIMEOUT=60

# ─── Optional: OAuth (if applicable) ──────────────────────────────────────
# CLIENT_ID=your-client-id
# CLIENT_SECRET=your-client-secret
# REDIRECT_URI=http://localhost:8080/callback

# ─── Optional: Product Audit Skill ────────────────────────────────────────
# PRODUCT_AUDIT_TEMPLATE_PATH=/path/to/product_audit_template.xlsx
# PRODUCT_AUDIT_OUTPUT_DIR=/path/to/output/
